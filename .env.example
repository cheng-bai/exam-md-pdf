# Project-local MinerU settings.
#
# Prefer pointing to the existing MinerU config file so the API token does not
# need to be duplicated in this repository.
MINERU_TOKEN_CONFIG=/path/to/mineru/config.json

# Alternative: set MINERU_API_TOKEN in your local .env or shell environment.
# Do not commit a real token.
# MINERU_API_TOKEN=
